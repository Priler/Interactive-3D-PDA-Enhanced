    -- Alife limits
    MAX_ALIFE_ID = 65534,
    NULL_PARENT_ID = 65535,
    
    -- Distance thresholds (meters)
    SQUAD_SEARCH_RADIUS = 150,
    NPC_NEARBY_RADIUS = 150,
    MIN_SMART_DISTANCE = 500,
    MAX_SMART_DISTANCE = 3000,
    
    -- Update intervals (milliseconds)
    UPDATE_FAST = 100,
    UPDATE_NORMAL = 500,
    UPDATE_SLOW = 1000,
    UPDATE_VERY_SLOW = 3000,
    
    -- Throttle keys
    THROTTLE_RAID_SEARCH = "raid_search",
    THROTTLE_TRADE_UPDATE = "trade_update",
    THROTTLE_TASK_UPDATE = "task_update",
    THROTTLE_FIND_UPDATE = "find_update",
    THROTTLE_BANTER_UPDATE = "banter_update",
}

-- ### LOCALIZED FUNCTIONS (for performance)
local pairs = pairs
local ipairs = ipairs
local type = type
local tostring = tostring
local tonumber = tonumber
local math_random = math.random
local math_floor = math.floor
local math_ceil = math.ceil
local math_min = math.min
local math_max = math.max
local string_find = string.find
local string_sub = string.sub
local string_format = string.format
local table_insert = table.insert
local table_remove = table.remove

-- Export for other scripts
