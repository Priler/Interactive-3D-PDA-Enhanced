local ss_target_id
local tm = task_manager.get_task_manager()
local pda_opened = false
local found = false
local base_cost = 200
local service_cost = 200
local relation = "unknown"
local npc_rank = "novice"
local npc_name = "Default"
local player_name = "Doofus" --for some reason i can't call db.actor:character_name() right away without it failing to compile
local message_decay = 13000
local message_sound = "pda_tips"
local sender_header = game.translate_string("stalker_search_snitch_header")
local sender_icon = "ui_inGame2_Radiopomehi"
local reached_rank = true
local pda_1_max_rank = 3
local pda_2_max_rank = 6
local pda_3_max_rank = 8
local tracking_task_active = false
local containsRussianE = false

local relation_multipliers = {
	["friend"] = 1,
	["neutral"] = 2,
	["enemy"] = 3,
	["unknown"] = 1,
}

local rank_multipliers = {
	["novice"] = 1,
	["trainee"] = 2,
	["experienced"] = 3,
	["professional"] = 4,
	["veteran"] = 5,
	["expert"] = 6,
	["master"] = 8,
	["legend"] = 10,
}

local rank_to_index = {
	["novice"] = 1,
	["trainee"] = 2,
	["experienced"] = 3,
	["professional"] = 4,
	["veteran"] = 5,
	["expert"] = 6,
	["master"] = 7,
	["legend"] = 8,
}

local message_sounds = {
	[0] = "pda_task",
	[1] = "pda_alarm",
	[2] = "pda_communication_lost",
	[3] = "pda_beep_1",
	[4] = "pda_beep_2",
	[5] = "pda_welcome",
	[6] = "pda_tips",
	[7] = "None",
}

local witness_radius = 250
local lie_chance_base = 0.15
local lie_chance_bandit = 0.40
local query_cooldown = 90
local query_cooldowns = {}
local archetypes = { mercenary = 3, vengeful = 3, cautious = 3, cocky = 2 }
local archetype_keys = { "mercenary", "vengeful", "cautious", "cocky" }
local dir_keys = { "n", "ne", "e", "se", "s", "sw", "w", "nw" }
local LOC_TEMPLATE_COUNT = 4

local function ss_pick_archetype()
	return archetype_keys[math.random(#archetype_keys)]
end

local function ss_get_lie_chance(comm)
	if comm == "bandit" or comm == "renegade" then
		return lie_chance_bandit
	end
	return lie_chance_base
end

local function ss_cardinal_from_dir(dir)
	if not dir then return "holding" end
	local x, z = dir.x, dir.z
	if (x * x + z * z) < 0.0025 then return "holding" end
	local angle = math.atan2(x, z)
	if angle < 0 then angle = angle + 2 * math.pi end
	local sector = math.floor(((angle + math.pi / 8) / (math.pi / 4))) % 8
	return dir_keys[sector + 1] or "holding"
end

local function ss_collect_smarts()
	local smarts = {}
	local smart_ini = ini_file("misc\\simulation.ltx")
	smart_ini:section_for_each(function(section)
		local smart = SIMBOARD and SIMBOARD.smarts_by_names and SIMBOARD.smarts_by_names[section]
		if smart then
			local lid = game_graph():vertex(smart.m_game_vertex_id):level_id()
			smarts[smart.id] = lid
		end
	end)
	return smarts
end

local function ss_nearest_smart(se_target)
	local smarts = ss_collect_smarts()
	local target_lid = game_graph():vertex(se_target.m_game_vertex_id):level_id()
	local target_pos = se_target.position
	local best, best_dist
	for sid, slid in pairs(smarts) do
		if slid == target_lid then
			local s = alife_object(sid)
			if s and s.position then
				local d = target_pos:distance_to(s.position)
				if (not best_dist) or d < best_dist then
					best_dist = d
					best = s
				end
			end
		end
	end
	return best
end

local function ss_random_lie_smart(se_target)
	local smarts = ss_collect_smarts()
	local pool = {}
	local target_lid = game_graph():vertex(se_target.m_game_vertex_id):level_id()
	local truth = ss_nearest_smart(se_target)
	local truth_id = truth and truth.id
	for sid, slid in pairs(smarts) do
		if sid ~= truth_id then
			local s = alife_object(sid)
			if s then pool[#pool + 1] = s end
		end
	end
	if #pool == 0 then return truth end
	return pool[math.random(#pool)]
end

local function ss_find_witness(se_target, radius)
	if not se_target then return nil end
	local target_pos = se_target.position
	local target_lid = game_graph():vertex(se_target.m_game_vertex_id):level_id()
	local witnesses = {}
	for i = 1, 65534 do
		local se = alife_object(i)
		if se and IsStalker(nil, se:clsid()) and se:alive() and se.id ~= se_target.id and se.id ~= AC_ID then
			local se_lid = game_graph():vertex(se.m_game_vertex_id):level_id()
			if se_lid == target_lid and se.position then
				local d = se.position:distance_to(target_pos)
				if d <= radius then
					local comm = se:community()
					if comm ~= "monolith" and comm ~= "zombied" and comm ~= "greh" then
						witnesses[#witnesses + 1] = se
					end
				end
			end
		end
	end
	if #witnesses == 0 then return nil end
	return witnesses[math.random(#witnesses)]
end

local function ss_build_message(loc_name, dir_key, archetype)
	local loc_tmpl = game.translate_string("ss_loc_" .. math.random(1, LOC_TEMPLATE_COUNT))
	local dir_str = game.translate_string("ss_dir_" .. dir_key)
	local tail_n = archetypes[archetype] or 3
	local tail = game.translate_string("ss_tail_" .. archetype .. "_" .. math.random(1, tail_n))
	local loc_clause
	if loc_tmpl:find("%%s") then
		loc_clause = strformat(loc_tmpl, loc_name)
	else
		loc_clause = loc_tmpl .. " " .. loc_name
	end
	return loc_clause .. ". " .. dir_str .. ". " .. tail
end

local function ss_cardinal_from_xz(dx, dz)
	if (dx * dx + dz * dz) < 4 then return "holding" end
	local angle = math.atan2(dx, dz)
	if angle < 0 then angle = angle + 2 * math.pi end
	local sector = math.floor(((angle + math.pi / 8) / (math.pi / 4))) % 8
	return dir_keys[sector + 1] or "holding"
end

local function ss_refund_and_notify(price, witness_icon, decay)
	if not db.actor then return end
	if price and price > 0 then
		db.actor:give_money(price)
	end
	local header = game.translate_string("ss_anonymous_sender")
	local body = game.translate_string("ss_target_lost_refund")
	db.actor:give_game_news(header, body, witness_icon, 0, decay)
end

local function ss_dispatch_tip(target_id, archetype, is_lying, witness_icon, decay, sound, price)
	local se0 = alife_object(target_id)
	local start_tg = time_global()

	if not se0 then
		ss_refund_and_notify(price, witness_icon, decay)
		return
	end

	local pos0 = se0.position
	local lid0 = game_graph():vertex(se0.m_game_vertex_id):level_id()
	local ev_id = "ss_tip_e_" .. target_id .. "_" .. start_tg
	local ac_id = "ss_tip_a_" .. target_id .. "_" .. start_tg

	local function deliver()
		if not db.actor then return true end

		local se = alife_object(target_id)
		if not se then
			ss_refund_and_notify(price, witness_icon, decay)
			return true
		end

		local dir_key
		if is_lying then
			local pool = { "n", "ne", "e", "se", "s", "sw", "w", "nw", "holding" }
			dir_key = pool[math.random(#pool)]
		else
			local lid1 = game_graph():vertex(se.m_game_vertex_id):level_id()
			if lid1 ~= lid0 then
				dir_key = "holding"
			else
				local p1 = se.position
				dir_key = ss_cardinal_from_xz(p1.x - pos0.x, p1.z - pos0.z)
			end
		end

		local smart
		if is_lying then
			smart = ss_random_lie_smart(se)
		else
			smart = ss_nearest_smart(se)
		end
		local loc_name
		if smart then
			loc_name = game.translate_string("st_" .. smart:name() .. "_name")
		else
			loc_name = game.translate_string("ss_unknown_location")
		end

		local body = ss_build_message(loc_name, dir_key, archetype)
		local header = game.translate_string("ss_anonymous_sender")
		db.actor:give_game_news(header, body, witness_icon, 0, decay)
		if sound ~= "None" then
			xr_sound.set_sound_play(AC_ID, sound)
		end
		return true
	end

	-- fire once after ~5s instead of busy-polling time_global every frame.
	CreateTimeEvent(ev_id, ac_id, 5, deliver)
end

local function ss_check_cooldown(name)
	if not name then return 0 end
	local key = string.lower(name)
	local tg = time_global()
	local exp = query_cooldowns[key]
	if exp and tg < exp then
		return math.ceil((exp - tg) / 1000)
	end
	return 0
end

local function ss_set_cooldown(name)
	if not name then return end
	query_cooldowns[string.lower(name)] = time_global() + (query_cooldown * 1000)
end

function loadsettings()
	if not pda_inter_mcm then return end
	local g = pda_inter_mcm.get_config

	local md = g("ss_message_decay")
	if md then message_decay = md * 1000 end

	local ms = g("ss_message_sound")
	if ms and message_sounds[ms] then message_sound = message_sounds[ms] end

	pda_1_max_rank = g("ss_pda_1_max_rank") or pda_1_max_rank
	pda_2_max_rank = g("ss_pda_2_max_rank") or pda_2_max_rank
	pda_3_max_rank = g("ss_pda_3_max_rank") or pda_3_max_rank
	base_cost = g("ss_base_cost") or base_cost
	relation_multipliers["friend"]      = g("ss_friend_multiplier")      or relation_multipliers["friend"]
	relation_multipliers["neutral"]     = g("ss_neutral_multiplier")     or relation_multipliers["neutral"]
	relation_multipliers["enemy"]       = g("ss_enemy_multiplier")       or relation_multipliers["enemy"]
	rank_multipliers["novice"]          = g("ss_novice_multiplier")       or rank_multipliers["novice"]
	rank_multipliers["trainee"]         = g("ss_trainee_multiplier")      or rank_multipliers["trainee"]
	rank_multipliers["experienced"]     = g("ss_experienced_multiplier")  or rank_multipliers["experienced"]
	rank_multipliers["professional"]    = g("ss_professional_multiplier") or rank_multipliers["professional"]
	rank_multipliers["veteran"]         = g("ss_veteran_multiplier")      or rank_multipliers["veteran"]
	rank_multipliers["expert"]          = g("ss_expert_multiplier")       or rank_multipliers["expert"]
	rank_multipliers["master"]          = g("ss_master_multiplier")       or rank_multipliers["master"]
	rank_multipliers["legend"]          = g("ss_legend_multiplier")       or rank_multipliers["legend"]
	witness_radius      = g("ss_witness_radius")     or witness_radius
	lie_chance_base     = g("ss_lie_chance_base")    or lie_chance_base
	lie_chance_bandit   = g("ss_lie_chance_bandit")  or lie_chance_bandit
	query_cooldown      = g("ss_query_cooldown")     or query_cooldown
end

local function actor_on_first_update()
	reached_rank = true
end



