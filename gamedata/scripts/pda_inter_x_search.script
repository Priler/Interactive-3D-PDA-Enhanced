--ranks.get_player_rank_name()
--ranks.get_se_obj_rank_name(se_obj)

		function CheckRelation(npc)
			if (xr_conditions.actor_enemy(db.actor,npc)) then
				return "enemy"
			elseif (xr_conditions.actor_neutral(db.actor,npc)) then
				return "neutral"
			elseif (xr_conditions.actor_friend(db.actor,npc)) then
				return "friend"
			else
				actor_menu.set_msg(1,"Error: npc's relation to actor doesn't match friend, neutral or enemy",4)
				return "unknown"
			end
		end
		
		
		
		
		function CheckFactionRelation(npc)
			if (game_relations.is_factions_enemies(get_actor_true_community(), npc:community())) then
				return "enemy"
			elseif (game_relations.is_factions_neutrals(get_actor_true_community(), npc:community())) then
				return "neutral"
			elseif (game_relations.is_factions_friends(get_actor_true_community(), npc:community())) then
				return "friend"
			else
				actor_menu.set_msg(1,"Error: npc's relation to actor doesn't match friend, neutral or enemy",10)
				return "unknown"
			end
		end
		
		function SnitchMessage(string_to_translate,relation_to_actor,npc_rank,type,count,decay)
		if(message_decay ~= 0) then
			local msg
			if (type == "random_npc_found") then
				msg = game.translate_string(string_to_translate .. "_" .. relation_to_actor .. "_" .. npc_rank .. "_" ..  tostring(math.random(count)))
			elseif (type == "random_default") then
				msg = game.translate_string(string_to_translate .. "_" .. tostring(math.random(count)))
			else
				msg = game.translate_string(string_to_translate)
			end
			db.actor:give_game_news(sender_header, msg, sender_icon, 0, decay)
		end
		if (message_sound ~= "None") then
			xr_sound.set_sound_play(AC_ID, message_sound)
		end
		end
	
		local function process_pda_info(npc,info_id)
			if info_id == "ui_pda" then
				pda_opened = true
			elseif info_id == "ui_pda_hide" then
				pda_opened = false
			end
		end

		function onkey_release(key)
			local bind = dik_to_bind(key)
			if ((bind == key_bindings.kWPN_FIREMODE_NEXT) and pda_opened) then
				try_open_search(db.actor)
			end
		end

		function try_open_search(actor)
			func_stalkersearch(actor or db.actor)
		end

		
