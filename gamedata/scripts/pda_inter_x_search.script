-- NOTE: currently unused. assigned_target_id is the real squad target field
-- (assigned_ss_target_id does not exist, so smart_id was always nil here)
local function is_smart_valid(squad_id)
	local squad = alife_object(squad_id)
	if squad then
		local smart_id = squad.assigned_target_id
		if smart_id then
			local smrt = SIMBOARD.smarts[smart_id]
			local smart = smrt and smrt.smrt
			if smart and (simulation_objects.base_smarts[smart:name()] == true) then
				--printf("setup_tracking_stalker_task | squad (%s) is targeting a base smart [%s]", squad_id, smart:name())
				return false
			end
		end
	end
	return true
end
	
---------------------------< Effects >---------------------------
xr_effects.setup_tracking_stalker_task = function(actor,npc,p)
-- p[1]: task_id
-- p[2]: true = scan all factions except for p[4], false = scan listed factions (p[4]+)
-- p[3]: true = scan npcs in current and connected levels only, false = scan all
-- p[4]+: factions that can be targetted; can be list

	local sim = alife()

	
	if (ss_target_id == nil or ss_target_id == AC_ID) then
		printf("! %s - no target found for task",p[1])
		return
	end
	
	local se_target = alife_object(ss_target_id)
	if not (se_target) then
		printe("! %s - no server object could be retrieved for (%s)",p[1],ss_target_id)
		return
	end
	
	local target_squad = se_target and se_target.group_id and se_target.group_id ~= 65535 and alife_object(se_target.group_id)
	if target_squad then
		sim_offline_combat.task_squads[target_squad.id] = true
	end
	
	-- Save var
	local target_comm = alife_character_community(se_target)
	local level_target = sim:level_name(game_graph():vertex(se_target.m_game_vertex_id):level_id())
	local level_task = level.name()
	local tbl = {
		lvl_task = level_task,
		lvl_target = level_target,
		ss_target_id = ss_target_id,
		target_comm = target_comm,
	}
	--save_var(db.actor, p[1], tbl)
	printdbg("- %s | setup_tracking_stalker_task | ss_target_id: %s - target_comm: %s - lvl_task: %s - lvl_target: %s", p[1], ss_target_id, target_comm, level_task, level_target)

	local function postpone_for_next_frame(ss_target_id)
		-- re-validate the target: the closure-captured se_target may have been released
		-- by the time this fires next frame (dangling C++ ref -> hard CTD).
		local se_t = alife_object(ss_target_id)
		if not (se_t and db.actor) then return true end
		local news_caption = game.translate_string(task_manager.task_ini:r_string_ex(p[1], "title")) or "error"
		local news_text = game.translate_string("st_mm_new_game_name") .. " " .. se_t:character_name() .. "\n " .. game.translate_string("st_mm_new_game_faction_2") .. " " .. game.translate_string(se_t:community()) .. "\n " .. game.translate_string("st_location") .. " " .. game.translate_string(level_target)
		db.actor:give_talk_message2(news_caption, news_text, se_t:character_icon(), "iconed_answer_item")
		return true
	end
	local setup_tg = time_global()
	local setup_ev_id = "ss_setup_track_e_" .. ss_target_id .. "_" .. setup_tg
	local setup_ac_id = "ss_setup_track_a_" .. ss_target_id .. "_" .. setup_tg
	CreateTimeEvent(setup_ev_id, setup_ac_id, 0, postpone_for_next_frame, ss_target_id)
end 


---------------------------< Task functor >---------------------------
task_functor.tracking_stalker_task_target_functor = function(task_id,field,p,tsk)
	if (field == "target") then
		if (tsk) then
			return ss_target_id
		end
	end
end


---------------------------< Task Status functor >---------------------------
task_status_functor.tracking_stalker_task_status_functor = function(tsk,task_id)

	if (tsk.stage == 0) then
		
		local id = ss_target_id
		
		if not (id) then
			actor_menu.set_msg(1,"ERROR: id not found",4)
			printdbg("ERROR: id not found")
			tracking_task_active = false
			return "fail"
		end
		
		local se_obj = id and alife_object(id)
		if not (se_obj) then
			actor_menu.set_msg(1,"ERROR: id is not alife_object",4)
			printdbg("ERROR: id is not alife_object")
			tracking_task_active = false
			return "fail"
		end
		
		if not (IsStalker(nil,se_obj:clsid())) then
			actor_menu.set_msg(1,"ERROR: id is not a stalker?!",4)
			printdbg("ERROR: id is not a stalker?")
			tracking_task_active = false
			return "fail"
		end
		
		if not (se_obj:alive()) then
			actor_menu.set_msg(1,game.translate_string("stalker_search_signal_lost"),4)
			tracking_task_active = false
			tm:set_task_cancelled("tracking_stalker_task") --cancel task
			SnitchMessage("stalker_search_snitch_target_signal_lost",nil,nil,"random_default",3,message_decay)
		end
		
	elseif (tsk.stage == 254) then
		actor_menu.set_msg(1,"ERROR: the hell's 254??",4)
		printdbg("ERROR: the hell's 254??")
		tracking_task_active = false
		return "fail"
	end
end


local function save_state(m_data)
	m_data.ss_target_id = ss_target_id
	m_data.reached_rank = reached_rank
	m_data.tracking_task_active = tracking_task_active
end

local function load_state(m_data)
	if (m_data.ss_target_id) then
		ss_target_id = m_data.ss_target_id
	end
	if (m_data.reached_rank) then
		reached_rank = m_data.reached_rank
	end
	if (m_data.tracking_task_active ~= nil) then
		tracking_task_active = m_data.tracking_task_active
	end
end

function on_game_start()
	RegisterScriptCallback("on_key_release",onkey_release)
	--RegisterScriptCallback("on_key_press", onKeyPress)
	RegisterScriptCallback("actor_on_info_callback",process_pda_info)
	RegisterScriptCallback("save_state",save_state)
	RegisterScriptCallback("load_state",load_state)
	RegisterScriptCallback("actor_on_first_update", actor_on_first_update)
	RegisterScriptCallback("on_option_change", loadsettings)  --MCM sends the same callback as ui_options
	loadsettings()
end