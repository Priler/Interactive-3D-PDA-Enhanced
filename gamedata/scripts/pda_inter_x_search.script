function func_stalkersearch(obj)
	start(obj)
end


-------------------------------------------------------------------
GUI = nil -- instance, don't touch
function start(obj)

	if (not obj) then
		return
	end
	
	hide_hud_inventory()
	
	if (tracking_task_active) then
		tm:set_task_cancelled("tracking_stalker_task") --cancel task
		tracking_task_active = false
		found = false
		SnitchMessage("stalker_search_snitch_target_signal_cancel",nil,nil,"random_default",3,message_decay)
	end
	
	if (not GUI) then
		GUI = UIFindActivePDA()
	end
	
	if (GUI) and (not GUI:IsShown()) then
		GUI:ShowDialog(true)
		GUI:Reset(obj)
		
		Register_UI("UIFindActivePDA","item_backpack")
	end
	

end
		

class "UIFindActivePDA" (CUIScriptWnd)

function UIFindActivePDA:__init() super()
	self:InitControls()
	self:InitCallBacks()
end

function UIFindActivePDA:__finalize()
end

function UIFindActivePDA:InitControls()
	self:SetWndRect(Frect():set(0,0,1024,768))
	self:SetAutoDelete(true)
	--self:Enable(true)

	local xml					= CScriptXmlInit()
	xml:ParseFile				("ui_items_backpack.xml")

	self.dialog					= xml:InitStatic("backpack", self)
	xml:InitStatic("backpack:background", self.dialog)

	self.input = xml:InitEditBox("backpack:input",self.dialog)
	self:Register(self.input,"fld_input")

	local in_pos = self.input:GetWndPos()
	local in_w = self.input:GetWidth()
	self.lbl_prompt = CUITextWnd()
	self.lbl_prompt:SetAutoDelete(true)
	self.lbl_prompt:SetWndRect(Frect():set(0, 0, in_w, 22))
	self.lbl_prompt:SetWndPos(vector2():set(in_pos.x, in_pos.y - 26))
	self.lbl_prompt:SetText(game.translate_string("ss_enter_name"))
	self.lbl_prompt:SetTextColor(GetARGB(255, 220, 220, 220))
	self.lbl_prompt:SetFont(GetFontLetterica18Russian())
	self.dialog:AttachChild(self.lbl_prompt)

	local btn = xml:Init3tButton("backpack:btn_cancel", self.dialog)
	self:Register(btn,"btn_cancel")

	btn = xml:Init3tButton("backpack:btn_ok", self.dialog)
	self:Register(btn,"btn_ok")
end

function UIFindActivePDA:InitCallBacks()
	self:AddCallback("btn_ok", ui_events.BUTTON_CLICKED, self.OnAccept, self)
	self:AddCallback("btn_cancel", ui_events.BUTTON_CLICKED, self.Close, self)
end

function UIFindActivePDA:Reset(obj)
	self.id = obj:id()
	self.section = obj:section()
	
	self.input:SetText("")
	self.input:Enable(true)
end

function UIFindActivePDA:Update()
	CUIScriptWnd.Update(self)
end

function UIFindActivePDA:OnAccept()
	local txt = self.input:GetText()

	if (txt == "" or txt == " ") then
		actor_menu.set_msg(1, game.translate_string("stalker_search_empty_string"), 4)
		self.input:SetText("")
		return
	end

	if (found == true) then
		if (db.actor:money() < self.price) then
			actor_menu.set_msg(1, strformat(game.translate_string("stalker_search_payment_not_enough"), self.price - db.actor:money(), self.price), 4)
			SnitchMessage("stalker_search_snitch_low_money", nil, nil, nil, nil, message_decay)
			found = false
			self:Close()
			return
		end

		local se_target = alife_object(self.target_id)
		if not (se_target and IsStalker(nil, se_target:clsid()) and se_target:alive()) then
			actor_menu.set_msg(1, game.translate_string("stalker_search_target_lost_before_accepted"), 4)
			found = false
			self:Close()
			return
		end

		-- deduct money
		db.actor:give_money(-self.price)
		actor_menu.set_msg(1, strformat(game.translate_string("stalker_search_transferring"), self.price), 4)

		ss_dispatch_tip(self.target_id, self.archetype, self.is_lying, self.witness_icon or sender_icon, message_decay, message_sound, self.price)

		ss_set_cooldown(self.target_name)
		found = false
		self:Close()
		return
	end

	-- russian E workaround
	if txt:find(string.char(197)) or txt:find(string.char(229)) then
		containsRussianE = true
	else
		containsRussianE = false
	end
	player_name = db.actor:character_name()
	if containsRussianE then
		player_name = player_name:gsub(string.char(168), string.char(197))
		player_name = player_name:gsub(string.char(184), string.char(229))
	end

	if (txt == player_name) then
		SnitchMessage("stalker_search_snitch_found_player", nil, nil, "random_default", 5, message_decay)
		self:Close()
		return
	end

	-- cooldown
	local cd_left = ss_check_cooldown(txt)
	if cd_left > 0 then
		actor_menu.set_msg(1, strformat(game.translate_string("ss_on_cooldown"), cd_left), 4)
		return
	end

	-- find target by name
	local se_target
	for i = 1, 65534 do
		local se = alife_object(i)
		if se and IsStalker(nil, se:clsid()) then
			local nm = se:character_name()
			if containsRussianE and nm then
				nm = nm:gsub(string.char(168), string.char(197))
				nm = nm:gsub(string.char(184), string.char(229))
			end
			if nm == txt then
				se_target = se
				break
			end
		end
	end

	if not se_target then
		actor_menu.set_msg(1, game.translate_string("stalker_search_cant_find_pda"), 4)
		return
	end

	if not se_target:alive() then
		SnitchMessage("stalker_search_snitch_dead_target", nil, nil, "random_default", 5, message_decay)
		self:Close()
		return
	end

	local rank = ranks.get_se_obj_rank_name(se_target)
	local pda_item = db.actor:item_in_slot(8)
	local pda_section = pda_item and tostring(pda_item:section()) or ""
	if ((pda_section == "device_pda_1") and (rank_to_index[rank] > pda_1_max_rank))
		or ((pda_section == "device_pda_2") and (rank_to_index[rank] > pda_2_max_rank))
		or ((pda_section == "device_pda_3") and (rank_to_index[rank] > pda_3_max_rank))
	then
		SnitchMessage("stalker_search_snitch_low_pda", nil, nil, nil, nil, message_decay)
		self:Close()
		return
	end

	-- witness scan
	local witness = ss_find_witness(se_target, witness_radius)
	if not witness then
		actor_menu.set_msg(1, game.translate_string("ss_no_witness"), 5)
		ss_set_cooldown(txt)  -- prevent name spam
		self:Close()
		return
	end

	-- relation (for price)
	local npc_r = level.object_by_id(se_target.id)
	local rel
	if npc_r and npc_r:alive() then
		rel = CheckRelation(npc_r)
	else
		rel = CheckFactionRelation(se_target)
	end

	local base_price = base_cost * (relation_multipliers[rel] or 1) * (rank_multipliers[rank] or 1)
	local rng = math.random(85, 120) / 100
	local price = math.floor(base_price * rng)

	-- roll archetype + lie chance
	local archetype = ss_pick_archetype()
	local lie_p = ss_get_lie_chance(witness:community())
	local lying = math.random() < lie_p

	self.target_id = se_target.id
	self.target_name = txt
	self.price = price
	self.archetype = archetype
	self.is_lying = lying
	self.witness_icon = witness:character_icon()

	-- feedback
	self.input:SetText(strformat(game.translate_string("stalker_search_payment_query"), price))
	self.input:Enable(false)
	found = true

	if (db.actor:money() < price) then
		self.input:SetText(strformat(game.translate_string("stalker_search_payment_not_enough"), price - db.actor:money(), price))
		SnitchMessage("stalker_search_snitch_low_money", nil, nil, nil, nil, message_decay)
	end
end



function UIFindActivePDA:OnKeyboard(dik, keyboard_action)
	local res = CUIScriptWnd.OnKeyboard(self,dik,keyboard_action)
	if (res == false) then
		local bind = dik_to_bind(dik)					
		if keyboard_action == ui_events.WINDOW_KEY_PRESSED then
			if dik == DIK_keys.DIK_ESCAPE then
				self:Close()
			end
		end
	end
	return res
end

function UIFindActivePDA:Close()
	found = false

	self:HideDialog()

	Unregister_UI("UIFindActivePDA")
end
	


