M_locked = false
removelet = false
function on_before_key_press(key, action, dis,flags)
	local ssub = string.sub
	if GUI then
		GUI:managecontrols(key, action)
	end
	if not M_locked then
		if GUI and get_console_cmd(1,"g_3d_pda") then
			if GUI.notes_input_box then GUI.notes_input_box:CaptureFocus(false) end
			if GUI.trade_quan_input then GUI.trade_quan_input:CaptureFocus(false) end
			if GUI.stalker_box_find then GUI.stalker_box_find:CaptureFocus(false) end
			if GUI.notes_picker_input then GUI.notes_picker_input:CaptureFocus(false) end
		end
		RemoveTimeEvent("delay_pda_var_set2", "delay_pda_var_set3")
		return 
	end
	block_input()
	if removelet then -- roundway to fix doubling of capital letters
		removelet = false
		if GUI.notes_input_box and GUI.notes_input_box:IsShown() then
			local newstr = ssub(GUI.notes_input_box:GetText(),1, -1)
			GUI.notes_input_box:SetText(newstr)
		end
		if GUI.notes_picker_input and GUI.notes_picker_input:IsShown() then
			local newstr = ssub(GUI.notes_picker_input:GetText(),1, -1)
			GUI.notes_picker_input:SetText(newstr)
		end
		if GUI.stalker_box_find and GUI.stalker_box_find:IsShown() then
			local newstr = ssub(GUI.stalker_box_find:GetText(),1, -1)
			GUI.stalker_box_find:SetText(newstr)
		end
		if GUI.trade_quan_input and GUI.trade_quan_input:IsShown() then
			local newstr = ssub(GUI.trade_quan_input:GetText(),1, -1)
			GUI.trade_quan_input:SetText(newstr)
		end
	end
	if exc_key_btns[key] then
		RemoveTimeEvent("delay_pda_var_set2", "delay_pda_var_set3")
		removelet = true
	end
	if (key ~= 1) and (key ~= 337) and (key ~= 338) then
		flags.ret_value = false
	end
end

local krelease_og = bind_stalker_ext.on_key_release
function bind_stalker_ext.on_key_release(binder,key)
	if not M_locked then
		return krelease_og(binder,key)
	else
		return false
	end
end


