-- ### TAB EXCLUSION
-- set tabs to false to hide them from the PDA interface
-- tab numbers: 1=Raid, 2=Buy Info, 3=Games, 4=Trade, 5=Notes, 6=Comms, 7=Tasks
local tab_enabled_defaults = {
	[1] = true,   -- Raid
	[2] = true,   -- Buy Info
	[3] = true,   -- Games
	[4] = true,   -- Trade (Buy Item)
	[5] = true,   -- Notes
	[6] = true,   -- Comms (Banter)
	[7] = true,   -- Tasks
}

-- MCM key names for each tab
local tab_mcm_keys = {
	[1] = "tab_raid_enabled",
	[2] = "tab_info_enabled",
	[3] = "tab_games_enabled",
	[4] = "tab_trade_enabled",
	[5] = "tab_notes_enabled",
	[6] = "tab_comms_enabled",
	[7] = "tab_tasks_enabled",
}

-- Function to check if a tab is enabled (checks MCM first, then defaults)
function is_tab_enabled(tab_num)
	if ui_mcm and tab_mcm_keys[tab_num] then
		local val = pda_inter_mcm.get_config(tab_mcm_keys[tab_num])
		if val ~= nil then
			return val
		end
	end
	return tab_enabled_defaults[tab_num]
end

function is_market_category_enabled(group)
	if not group then return true end
	if ui_mcm then
		local val = pda_inter_mcm.get_config("mkt_cat_" .. group)
		if val ~= nil then return val end
	end
	return true
end

